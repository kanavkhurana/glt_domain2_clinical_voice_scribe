PORT=5000
OPENAI_API_KEY=your_openai_key_here
SARVAM_API_KEY=your_sarvam_key_here
FRONTEND_ORIGIN=http://localhost:5173
SARVAM_API_MODE=rest

OPENAI_EXTRACT_MODEL=gpt-4o-mini
OPENAI_SYNTHESIS_MODEL=gpt-4o-mini

# DB adapter: "local" (JSON file, no install needed) or "supabase" (set keys below)
DB_PROVIDER=local

# Supabase — only needed when DB_PROVIDER=supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key
